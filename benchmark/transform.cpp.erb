#include <type_traits>
#include <tuple>
#include "meta.h" // Garanta que o caminho para o seu meta.h está correto aqui

template <typename T>
struct make_pointer { using type = T*; };

int main() {
<% if $backend == 'baseline' %>
    // 1. Linha de base
    <% (1..n).each do |i| %>
    typename make_pointer<int>::type p<%= i %>;
    <% end %>

<% elsif $backend == 'std_tuple' %>
    // 2. Abordagem via std::tuple
    using Types = std::tuple<<%= (1..n).map { "int" }.join(', ') %>>;
    using Transformed = std::tuple<<%= (1..n).map { "int*" }.join(', ') %>>;
    [[maybe_unused]] Transformed t;

<% elsif $backend == 'hapi' %>
    // Functor compatível com a topologia do HAPI
    struct HapiMakePointer {
        template <typename O>
        struct Apply {
            using Expr = O*;
        };
    };

    // 3. Teste real usando a topologia do HAPI (Map + Chain)
    using HapiInputChain = hapi::Chain<<%= (1..n).map { "int" }.join(', ') %>>;
    using HapiTransformed = typename hapi::Map<HapiMakePointer, HapiInputChain>::Expr;
    
    [[maybe_unused]] HapiTransformed hapi_instance;
<% end %>
    return 0;
}