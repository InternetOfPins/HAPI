{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "HAPI: Compile Tests",
            "type": "cppbuild",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-O2",
                "-Iinclude",
                "-I../OneList",           // adjust if OneList is sibling folder
                "${file}",
                "-o",
                "${workspaceFolder}/build/tests/${fileBasenameNoExtension}.out"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compile HAPI compile-time tests"
        }
    ]
}